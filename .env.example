# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - add to .gitignore

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Option 1: Neon.tech
DATABASE_URL=postgresql://user:password@neon-host.neon.tech/db-name

# Option 2: Railway PostgreSQL (auto-provided)
# DATABASE_URL=postgresql://user:password@railway-host:5432/db-name

# Connection Pool Sizing
PG_POOL_MIN=5
PG_POOL_MAX=20

# ============================================
# REDIS / CELERY
# ============================================
# Option 1: Upstash Redis (recommended for managed)
REDIS_URL=rediss://default:your-password@redis-endpoint.upstash.io:38317

# Option 2: Railway Redis (auto-provided)
# REDIS_URL=redis://:password@railway-host:6379/0

# Option 3: Local development
# REDIS_URL=redis://localhost:6379/0

# ============================================
# APPLICATION
# ============================================
# Environment mode
APP_ENV=development
ENVIRONMENT=development
NODE_ENV=development

# Security Keys (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-generated-secret-key-here
WEBHOOK_SHARED_SECRET=your-generated-webhook-secret-here

# Timezone
TZ=Asia/Kolkata

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_CONCURRENCY=4

# ============================================
# FRONTEND / WEBHOOKS
# ============================================
# Your frontend URL (set this in Railway after Vercel deployment)
WEBHOOK_RESULTS_URL=https://your-vercel-url.vercel.app/api/webhooks/results

# Webhook security headers
WEBHOOK_SIGNATURE_HEADER=X-Aspira-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Aspira-Timestamp
WEBHOOK_MAX_CLOCK_SKEW_SECONDS=300

# ============================================
# EMAIL / NOTIFICATIONS (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=alerts@yourdomain.com

# ============================================
# FEATURE FLAGS (Migration flags - enable gradually)
# ============================================
MIGRATION_RECONCILIATION_ENABLED=false
MIGRATION_RECONCILIATION_SWEEP_ENABLED=false
MIGRATION_DUAL_WRITE_SLA_ETA=false
MIGRATION_DUAL_WRITE_QUEUE_ROUTING=false
MIGRATION_READ_NEW_DASHBOARD_MODEL=false
MIGRATION_READ_NEW_API_MODEL=false
MIGRATION_DISABLE_LEGACY_WRITES=false
MIGRATION_ENABLE_CYCLE_LINEAGE=false

# ============================================
# TAT / PROCESSING DEFAULTS
# ============================================
DEFAULT_PROCESSING_TIME_MINS=60
ALLOW_DOCTOR_SAMPLE_CREATE=false
